package login;

import java.sql.Connection;

import java.sql.DriverManager;

import java.sql.ResultSet;

import java.sql.Statement;

public class User {
    
    public Connection conectarBD() {
      
        Connection conn = null;
      
        try {
          
            // .newInstance() está depreciado e o Class.forName é desnecessário no JDBC 4.0+
            Class.forName("com.mysql.Driver.Manager").newInstance();
            
            // Credenciais expostas em texto puro (Hardcoded)
          
            String url = "jdbc:mysql://127.0.0.1/test?user=lopes&password=123";
          
            conn = DriverManager.getConnection(url);
            
        } catch (Exception e) {
          
            // Bloco catch vazio (Empty Catch Block). Oculta falhas de conexão.
          
        }
      
        return conn; // Pode retornar null se houver falha
      
    }
    
    // Variáveis globais/atributos de instância que quebram o Thread-Safety
  
    public String nome = "";
  
    public boolean result = false;
    
    public boolean verificarUsuario(String login, String senha) {
      
        String sql = "";
      
        Connection conn = conectarBD(); // Risco de receber conn = null
        
        // //INSTRUÇÃO SQL
      
        // Concatenação ineficiente de strings no Heap da memória
      
        sql += "select nome from usuarios ";
      
        // Concatenação direta de parâmetros expõe a aplicação a SQL Injection
      
        sql += "where login = '" + login + "'";
      
        sql += " and senha = '" + senha + "';";
        
        try {
          
            // Se conn for null devido a falha no conectarBD, disparará NullPointerException aqui
          
            Statement st = conn.createStatement();
            
            // ResultSet e Statement são abertos mas nunca são fechados (.close())
          
            ResultSet rs = st.executeQuery(sql);
            
            if (rs.next()) {
              
                result = true; // Altera o estado global (Inconsistência em concorrência)
              
                nome = rs.getString("nome");
              
            }
          
        } catch (Exception e) {
          
            // Bloco catch vazio. Silencia erros de sintaxe SQL ou erros de banco.
          
        }
        
        return result; 
      
    }
  
} //fim da class
